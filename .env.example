# ============================================
# HR Management System - Environment Variables
# ============================================
# Copy this file to .env and update the values
# For Docker: Most values are set in docker-compose.yml
# For Local Dev: Update DB_HOST to 'localhost'

# ============================================
# Server Configuration
# ============================================
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
ENVIRONMENT=development

# ============================================
# Database Configuration
# ============================================
# For Docker: Use DB_HOST=postgres
# For Local: Use DB_HOST=localhost
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=hrms
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ============================================
# JWT Configuration
# ============================================
# IMPORTANT: Change these secrets in production!
# Generate strong random strings for production use
JWT_ACCESS_SECRET=your-access-secret-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# ============================================
# New Relic Configuration (Optional)
# ============================================
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=HRMS
NEW_RELIC_ENABLED=false

# ============================================
# OpenAI Configuration (Optional - for AI Assistant)
# ============================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# ============================================
# SMTP Configuration (Optional - for Email Notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@hrms.com
SMTP_ENABLED=false

# For Gmail, you need to use an App Password:
# 1. Enable 2-Step Verification
# 2. Go to Google Account > Security > App passwords
# 3. Generate an app password and use it here

# ============================================
# Storage Configuration
# ============================================
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_MAX_FILE_SIZE=10485760

# Allowed file types (comma-separated extensions)
# Currently configured in code: .pdf, .doc, .docx, .jpg, .jpeg, .png

# ============================================
# AWS S3 Configuration (Optional - for Cloud Storage)
# ============================================
# Uncomment and configure if using S3 storage
# STORAGE_TYPE=s3
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
